          "example": "let age = 20;\nlet status = age >= 18 ? 'adult' : 'minor';"
        },
        {
          "term": "if statement",
          "english": "if statement",
          "russian": "условный оператор «если»",
          "example": "if (score >= 90) {\n  console.log('A');\n}"
        },
        {
          "term": "else",
          "english": "else",
          "russian": "иначе (блок при ложном условии)",
          "example": "if (x > 0) {\n  console.log('positive');\n} else {\n  console.log('not positive');\n}"
        },
        {
          "term": "else if",
          "english": "else if",
          "russian": "иначе если (цепочка условий)",
          "example": "if (x > 0) {\n  // positive\n} else if (x < 0) {\n  // negative\n} else {\n  // zero\n}"
        },
        {
          "term": "switch",
          "english": "switch statement",
          "russian": "оператор множественного выбора",
          "example": "switch (day) {\n  case 1: console.log('Mon'); break;\n  default: console.log('Other');\n}"
        },
        {
          "term": "case",
          "english": "case",
          "russian": "вариант в switch",
          "example": "switch (x) {\n  case 1: // do something\n  case 2: // do something else\n}"
        },
        {
          "term": "default",
          "english": "default",
          "russian": "действие по умолчанию в switch",
          "example": "switch (x) {\n  default: console.log('unknown');\n}"
        },
        {
          "term": "break",
          "english": "break",
          "russian": "прервать выполнение цикла или switch",
          "example": "for (let i = 0; i < 10; i++) {\n  if (i === 5) break;\n}"
        },
        {
          "term": "continue",
          "english": "continue",
          "russian": "перейти к следующей итерации цикла",
          "example": "for (let i = 0; i < 5; i++) {\n  if (i === 2) continue;\n  console.log(i);\n}"
        },
        {
          "term": "for loop",
          "english": "for loop",
          "russian": "цикл со счётчиком",
          "example": "for (let i = 0; i < 5; i++) {\n  console.log(i);\n}"
        },
        {
          "term": "while loop",
          "english": "while loop",
          "russian": "цикл с предусловием",
          "example": "let i = 0;\nwhile (i < 5) {\n  console.log(i);\n  i++;\n}"
        },
        {
          "term": "do...while loop",
          "english": "do...while loop",
          "russian": "цикл с постусловием",
          "example": "let i = 0;\ndo {\n  console.log(i);\n  i++;\n} while (i < 5);"
        },
        {
          "term": "infinite loop",
          "english": "infinite loop",
          "russian": "бесконечный цикл (ошибка)",
          "example": "while (true) {\n  // This will run forever!\n}"
        }
      ]
    },
    {
      "id": "functions",
