        },
        {
          "term": "setter",
          "english": "setter",
          "russian": "сеттер (метод для установки значения)",
          "example": "class User {\n  set age(value) {\n    this._age = value;\n  }\n}"
        },
        {
          "term": "instanceof",
          "english": "instanceof operator",
          "russian": "проверяет, принадлежит ли объект классу",
          "example": "user instanceof User  // true"
        }
      ]
    },
    {
      "id": "arrays",
