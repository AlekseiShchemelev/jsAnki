          "example": "function greet(name) {\n  return 'Hello ' + name;\n}"
        },
        {
          "term": "function declaration",
          "english": "function declaration",
          "russian": "объявление функции (через function f() {})",
          "example": "function add(a, b) {\n  return a + b;\n}"
        },
        {
          "term": "function expression",
          "english": "function expression",
          "russian": "функциональное выражение (const f = function() {})",
          "example": "const add = function(a, b) {\n  return a + b;\n};"
        },
        {
          "term": "arrow function",
          "english": "arrow function",
          "russian": "стрелочная функция (() => {})",
          "example": "const add = (a, b) => a + b;\nconst greet = name => `Hello ${name}`;"
        },
        {
          "term": "parameter",
          "english": "parameter",
          "russian": "параметр (переменная в определении функции)",
          "example": "function greet(name) { // name is parameter\n  console.log(name);\n}"
        },
        {
          "term": "argument",
          "english": "argument",
          "russian": "аргумент (значение, передаваемое при вызове)",
          "example": "greet('John'); // 'John' is argument"
        },
        {
          "term": "return",
          "english": "return statement",
          "russian": "оператор возврата значения из функции",
          "example": "function add(a, b) {\n  return a + b;\n}"
        },
        {
          "term": "callback",
          "english": "callback function",
          "russian": "функция обратного вызова (передаётся как аргумент)",
          "example": "setTimeout(() => {\n  console.log('Done!');\n}, 1000);"
        },
        {
          "term": "anonymous function",
          "english": "anonymous function",
          "russian": "анонимная функция (без имени)",
          "example": "btn.addEventListener('click', function() {\n  console.log('clicked');\n});"
        },
        {
          "term": "recursion",
          "english": "recursion",
          "russian": "рекурсия (вызов функции самой себя)",
          "example": "function factorial(n) {\n  if (n <= 1) return 1;\n  return n * factorial(n - 1);\n}"
        },
        {
          "term": "IIFE",
          "english": "Immediately Invoked Function Expression",
          "russian": "немедленно вызываемое функциональное выражение",
