          "example": "class Admin extends User {\n  constructor(name, role) {\n    super(name);\n    this.role = role;\n  }\n}"
        },
        {
          "term": "static",
          "english": "static keyword",
          "russian": "статическое свойство/метод класса",
          "example": "class User {\n  static create() { return new User(); }\n}"
        },
        {
          "term": "getter",
          "english": "getter",
          "russian": "геттер (метод для получения значения)",
